class decoder(nn.Module):
    def __init__(self, l_dim, h_dim, fp_dim):
        super().__init__()

        self.model = nn.Sequential(
            nn.Linear(l_dim, h_dim),
            nn.ReLU(),
            nn.Linear(h_dim, fp_dim),
            nn.Sigmoid()
        )

        return

    def forward(self, z):
        return self.model(z)

    pass
